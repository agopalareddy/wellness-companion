# Copy to .env and set values locally or on your deployment host.
# Never commit .env — it is gitignored.

# Google AI Studio API key (optional — deployer-level fallback)
# Get one at https://aistudio.google.com/apikey
# Set a spending limit at https://aistudio.google.com/spend
# When set, the app uses AI Studio instead of Vertex AI / ADC.
# End users can also supply their own key via the UI (takes precedence).
GOOGLE_API_KEY=

# Provider dashboard auth (required for CRUD)
PROVIDER_PASSCODE=

# Patient profile passcodes (one per demo patient ID)
PASSCODE_ARTHUR=
PASSCODE_BEATRICE=
PASSCODE_CHARLES=

# Set true only on local demo machines to expose passcodes via the UI API
EXPOSE_DEMO_PASSCODES=false
