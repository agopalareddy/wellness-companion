# Copy to .env and set values locally or on your deployment host.
# Never commit .env — it is gitignored.

# Provider dashboard auth (required for CRUD)
PROVIDER_PASSCODE=

# Patient profile passcodes (one per demo patient ID)
PASSCODE_ARTHUR=
PASSCODE_BEATRICE=
PASSCODE_CHARLES=

# Set true only on local demo machines to expose passcodes via the UI API
EXPOSE_DEMO_PASSCODES=false
